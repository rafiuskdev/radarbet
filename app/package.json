{
  "name": "radarbet",
  "version": "1.1.2",
  "description": "RadarBet — Radar de odds ao vivo",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite dev",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "release": "electron-vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.radarbet.app",
    "productName": "RadarBet",
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "rafiuskdev",
      "repo": "radarbet"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/playwright/**",
      "!node_modules/playwright-core/**",
      "!node_modules/puppeteer/**",
      "!node_modules/@playwright/**",
      "!node_modules/modern-tar/**"
    ],
    "win": {
      "icon": "logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RadarBet",
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "playwright": "^1.60.0",
    "puppeteer": "^25.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
